# Connection profiles for a portable testrange plan (ADR-0015 / ADR-0016).
#
# Copy this to a local, gitignored `connect.toml` and select a profile by name:
#
#     cp examples/connect.toml.example connect.toml
#     # edit host/password + the [<profile>.uplinks] map for your backend
#     testrange run examples/hello_world.py --profile pve
#
# `--profile pve` reads the [pve] table from ./connect.toml; use
# `--profile other.toml:pve` to read it from a different file.
#
# One file holds MANY profiles, one per top-level table. A real `connect.toml`
# (and any `*.connect.toml`) is gitignored: it carries a password. The `.example`
# is the only profile tracked in git. Secrets live inline as plain strings —
# testrange backends are firewalled lab environments.

[pve]
driver = "proxmox"          # required: "proxmox" | "libvirt" | "mock"
host = "10.0.0.5"
user = "root@pam"           # optional; a bare "root" takes the @pam realm
password = "Target123!"
port = 8006                 # optional
verify_ssl = false          # optional (PVE ships a self-signed cert)
node = ""                   # optional; "" auto-detects the single node
backing_storage = "local"   # optional

# SSH is used only for volume byte I/O; it defaults to the API user/password.
# ssh_user = "root"
# ssh_password = "..."
# ssh_port = 22

# Named uplinks (ADR-0016): a plan's `Switch(uplink="<name>")` resolves here to a
# host iface/bridge. `egress` is the out-of-band bridge a NAT sidecar routes out
# of. Map as many as your plans reference; an unmapped name fails at preflight.
#
# Two value forms:
#   - string: just the bridge. The sidecar's MASQUERADE NIC DHCPs on it, so the
#     bridge must have DHCP+DNS behind it (e.g. a libvirt NAT network).
#   - table (NET-8): bridge + a static sidecar address, for a host-NAT'd bridge
#     that does NAT but not DHCP/DNS — gives the sidecar's uplink NIC a source IP
#     for the MASQUERADE and an explicit upstream resolver.
[pve.uplinks]
egress = "vmbr0"            # string form: the bridge has DHCP/DNS behind it
# lab = "vmbr3"            # another physical bridge a plain Switch(uplink=) can use

# Table form — a host-NAT bridge (NATs to the host's uplink, no DHCP/DNS server):
# [pve.uplinks.egress]
# bridge       = "vmbr9"
# sidecar_addr = "10.10.10.2/24"   # the sidecar's static IP on the uplink subnet
# gateway      = "10.10.10.1"      # the host's IP on that bridge
# dns          = ["1.1.1.1"]       # upstream resolver(s) the sidecar forwards to

# A second profile in the same file — a local libvirt host. No host/password:
# qemu:///system is reachable by any 'libvirt'-group member (no root). Per-run
# storage pools are driver-created, so there is no backing_pool knob.
[libvirt-local]
driver = "libvirt"
# uri = "qemu:///system"

# `egress` is the out-of-band host bridge a NAT sidecar routes out of. Use a
# dedicated libvirt NAT network (`tr-egress`, provisioned out-of-band — see
# docs/user/drivers/out-of-band-egress.md), NOT the shared `default`/`virbr0`.
[libvirt-local.uplinks]
egress = "tr-egress"
